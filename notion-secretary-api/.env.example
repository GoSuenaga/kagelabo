# Notion / Gemini（既存）
# NOTION_TOKEN=
# GEMINI_API_KEY=

# KAGE 本番URL（Notion用エクスポート /meta/notion-export で実URLを埋める。未設定ならプレースホルダ）
# KAGE_PUBLIC_URL=https://notion-secretary-api-production.up.railway.app

# Notion Memos に KAGE マニュアル（静的）・稼働情報（動的）を upsert する API 用シークレット
# KAGE_NOTION_SYNC_SECRET=
# 既定の Memos 以外の DB に書くときだけ指定
# NOTION_KAGE_DOCS_DB=
# 起動時に自動同期: dynamic | static | all（いずれも KAGE_NOTION_SYNC_SECRET 必須）
# KAGE_NOTION_SYNC_ON_STARTUP=dynamic

# --- 朝ニュース RSS（任意）---
# カンマ区切りで公式RSSのみ推奨（品質の要）
# KAGE_NEWS_RSS_FEEDS=https://www.publickey1.jp/atom.xml,https://example.com/rss
# タイトル・要約に含まれるとスコア加算（カンマ区切り・brainとマージ）
# KAGE_NEWS_KEYWORDS=AI,生成AI,広告,教育,RAG
# 含む記事を除外（カンマ区切り・小文字化して部分一致）
# KAGE_NEWS_MUTE_KEYWORDS=株価,芸能
# 環境キーワードの倍率（既定1.0）
# KAGE_NEWS_ENV_WEIGHT=1.0
# 1 にすると Profile 一般文から弱い語も拾う（ノイズ増・任意）
# KAGE_NEWS_MINING_PROFILE=0
# KAGE_NEWS_MAX_AGE_HOURS=36
# KAGE_NEWS_CACHE_SEC=3600
# KAGE_NEWS_TOP_N=8
# Cron でキャッシュ更新するとき: curl -H "X-Kage-Cron: $SECRET" "https://.../news/digest?refresh=1"
# KAGE_NEWS_CRON_SECRET=
# 朝ニュース「感想待ち」セッションの有効秒（既定 172800 = 48h）
# KAGE_NEWS_FEEDBACK_TTL_SEC=172800
